{
  "name": "bouncy-blobs-web",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:wasm": "cd crates && cargo build --target wasm32-unknown-unknown --release -p softbody-wasm && cd .. && wasm-bindgen --target web --out-dir src/physics/wasm crates/target/wasm32-unknown-unknown/release/softbody_wasm.wasm",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test ai-smoke",
    "test:e2e:lobby": "playwright test api-reachability navigation host-flow lobby-discovery local-player guest-play guest-sim",
    "test:e2e:capacity": "playwright test api-reachability room-capacity",
    "test:e2e:all": "playwright test",
    "record:match": "playwright test ai-content",
    "record:short": "playwright test --project=shorts match-short",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "publish:itch": "bash scripts/publish-itch.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "fflate": "^0.8.3",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "node-datachannel": "^0.32.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
