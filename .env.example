# Rooms / signaling backend (REST + WebRTC signaling)
# Dev: http://localhost:3000 (or http://<your-LAN-ip>:3000 for cross-device tests)
# Prod: https://www.sterlinglong.me
VITE_PARTY_API_URL=http://localhost:3000

# API key for the rooms backend. Exchanged at POST /api/auth/token for a
# short-lived session token; the raw key is no longer the gate on signalling.
VITE_MP_API_KEY=

# Cloudflare Turnstile public site key (web attestation). The matching secret
# lives in the arcadii backend env (TURNSTILE_SECRET). Optional in local dev.
VITE_TURNSTILE_SITE_KEY=

# Optional: Supabase auth (auth features disabled gracefully if unset)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: dev-only LAN IP, used to generate cross-device QR codes
VITE_LOCAL_LAN_IP=

# Optional: hides lobby/editor/sandbox for demo cuts
# VITE_DEMO=1
