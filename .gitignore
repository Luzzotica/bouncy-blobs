# Godot 4+ specific ignores
.godot/
/android/

# Local Supabase credentials (copy from config/supabase_env.example)
config/supabase.env

# Node
node_modules/
dist/
.DS_Store

# itch.io publish artifacts (built by scripts/publish-itch.sh)
dist-itch-*.zip

# Build artifacts
*.tsbuildinfo
test-results/
playwright-report/
playwright/output/

# Steam (dev-only App ID file; production binaries get the ID injected by Steam)
src-tauri/steam_appid.txt
# Steam SDK (vendored locally; not redistributable in source form)
src-tauri/resources/steamworks/

# Rust build artifacts
src-tauri/target/
crates/target/
**/target/

# wasm-pack / wasm-bindgen outputs
crates/softbody-wasm/pkg/

# Supabase CLI local state
**/supabase/.branches/
**/supabase/.temp/

# Environment files (keep .env.example)
.env
.env.local
.env.*.local

# Editor/agent configs
.aider.conf.yml
.cursor/
.opencode/
.pi/
.k2so/
.goosehints
.gutconfig.json
.vercel
.env*.local

# Consolidated marketing folder. The toolchain (marketing/steam-assets/) is
# tracked source; only the generated OUTPUT subfolders + pipeline workspaces
# (local-only, often large) are ignored. Only public/ assets ship with the game.
/marketing/steam/
/marketing/social/
/marketing/itch/
/marketing/video/
/marketing/shorts/
