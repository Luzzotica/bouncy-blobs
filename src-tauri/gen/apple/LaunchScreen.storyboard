                        <viewLayoutGuide key="safeArea" id="vDu-zF-Fre"/>
                        <!-- Paper cream #FFFAE6 — the game's canonical background. -->
                        <color key="backgroundColor" red="1" green="0.98" blue="0.902" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                        <constraints>
                            <constraint firstItem="lgo-01-img" firstAttribute="centerX" secondItem="5EZ-qb-Rvc" secondAttribute="centerX" id="lgo-cx-001"/>
                            <constraint firstItem="lgo-01-img" firstAttribute="centerY" secondItem="5EZ-qb-Rvc" secondAttribute="centerY" id="lgo-cy-002"/>
